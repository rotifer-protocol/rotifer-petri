{
  "$schema": "https://rotifer.dev/schemas/phenotype/v1.json",
  "gene": "polymarket-settler",
  "version": "0.1.0",
  "fidelity": "native",
  "description": "Settles resolved markets: detects closed markets with outcome prices and computes final PnL for open positions.",
  "input": {
    "type": "object",
    "properties": {
      "markets": { "type": "array", "items": { "$ref": "#/definitions/MarketSnapshot" }, "description": "All fetched market snapshots (includes closed/resolved)" },
      "funds": { "type": "array", "items": { "$ref": "#/definitions/FundConfig" }, "description": "Fund configurations for ownership lookup" }
    },
    "required": ["markets", "funds"]
  },
  "output": {
    "type": "object",
    "properties": {
      "settlements": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "fundId": { "type": "string" },
            "fundEmoji": { "type": "string" },
            "slug": { "type": "string" },
            "question": { "type": "string" },
            "pnl": { "type": "number", "description": "Realized PnL from settlement" },
            "entryPrice": { "type": "number" },
            "exitPrice": { "type": "number" }
          }
        },
        "description": "Settled trades with final PnL"
      }
    }
  }
}
